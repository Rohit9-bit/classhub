// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Visibility {
  PUBLIC
  ORGANIZATION
  PRIVATE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum FileType {
  PDF
  IMAGE
  VIDEO
  DOCUMENT
  ZIP
  OTHER
}

enum EntityType {
  NOTE
  ASSIGNMENT
  RESOURCE
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  profileUrl          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  password            String
  verifyCode          String?
  verifyCodeExpiry    DateTime?
  isVerified          Boolean              @default(false)
  organizationMembers OrganizationMember[]
  subjects            Subject[]
  units               Unit[]
  topics              Topic[]
  notes               Note[]
  assignments         Assignment[]
  files               File[]
  resources           Resource[]

  @@map("users")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationMembers OrganizationMember[]
  subjects            Subject[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           Role     @default(MEMBER)
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("organizationMembers")
}

model Subject {
  id             String   @id @default(cuid())
  name           String
  semester       Int
  slug           String   @unique
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  units          Unit[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [createdBy], references: [id])

  @@unique([organizationId, semester])
  @@index([createdBy])
  @@index([organizationId])
  @@map("subjects")
}

model Unit {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int
  slug        String   @unique
  subjectId   String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topics      Topic[]

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@unique([subjectId, order])
  @@index([createdBy])
  @@index([subjectId])
  @@map("units")
}

model Topic {
  id          String       @id @default(cuid())
  title       String
  description String?
  order       Int
  slug        String       @unique
  unitId      String
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  notes       Note[]
  assignments Assignment[]

  unit      Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  creator   User       @relation(fields: [createdBy], references: [id])
  resources Resource[]

  @@unique([unitId, order])
  @@index([createdBy])
  @@index([unitId])
  @@map("topics")
}

model Note {
  id          String     @id @default(cuid())
  title       String
  content     String?
  topicId     String
  uploadedBy  String
  visibility  Visibility @default(ORGANIZATION)
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  topic          Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  uploadedByUser User   @relation(fields: [uploadedBy], references: [id])
  files          File[]

  @@index([topicId])
  @@map("notes")
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  topicId     String
  dueDate     DateTime
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id])
  files   File[]

  @@index([createdBy])
  @@index([topicId])
  @@map("assignments")
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  url         String
  type        FileType
  description String?
  topicId     String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic   Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdBy], references: [id])

  @@unique([topicId, url])
  @@index([createdBy])
  @@index([topicId])
  @@map("resources")
}

model File {
  id           String   @id @default(cuid())
  fileUrl      String
  type         FileType
  size         BigInt
  noteId       String?
  assignmentId String?
  uploadedBy   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedByUser User        @relation(fields: [uploadedBy], references: [id])
  note           Note?       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  assignment     Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("files")
}
